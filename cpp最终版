// 骨头（可收集物）
struct Bone {
    float x, y;
    int w, h;
    bool active = true;    // 是否仍活跃（未收集、未移出屏幕）
    Bone(float _x, float _y, int _w, int _h) : x(_x), y(_y), w(_w), h(_h) {}
};

// 障碍物
struct Obstacle {
    float x, y;
    ObstacleType type;
    int w, h;
    bool active = true;
    Obstacle(float _x, float _y, ObstacleType _type, int _w, int _h)
        : x(_x), y(_y), type(_type), w(_w), h(_h) {
    }
};

// 道具
struct Prop {
    float x, y;
    PropType type;
    int w, h;
    bool active = true;
    Prop(float _x, float _y, PropType _type, int _w, int _h)
        : x(_x), y(_y), type(_type), w(_w), h(_h) {
    }
};

// ==========================================
// 玩家类
// ==========================================
class Player {
public:
    float x, y;                   // 位置
    float vx, vy;                 // 速度（横向几乎固定，纵向受重力影响）
    int w = 50, h = 60;          // 碰撞盒宽高（由图片实际尺寸覆盖）

    bool onGround = false;        // 是否站在地面上
    bool canDoubleJump = true;    // 是否还能二段跳
    int  bonesCollected = 0;      // 已收集的骨头数量
    int  jumpCount = 0;          // 当前已经跳跃的次数（用于二段跳判断）
    VehicleType vehicle = SURFBOARD; // 当前载具

    // 血量与状态计时器
    int maxHp = 5;                // 最大血量
    int hp = 5;                  // 当前血量
    int invulnerableTimer = 0;   // 无敌帧计数（受伤后短暂无敌）
    int slowdownTimer = 0;       // 减速计时（受伤后短暂减速）

    // 道具效果剩余时间（帧数）
    int magnetTimer = 0;         // 磁铁剩余时间
    int shieldTimer = 0;         // 护盾剩余时间

    // 构造函数：将玩家放在起始位置
    Player() {
        x = 150;
        y = GROUND_Y - 60;       // 站在地面上
        vx = vy = 0;
        maxHp = 5; hp = 5;
        invulnerableTimer = 0;
        slowdownTimer = 0;
        magnetTimer = 0;
        shieldTimer = 0;
    }

    // 更新所有计时器（每帧调用）
    void updateTimers() {
        if (invulnerableTimer > 0) invulnerableTimer--;
        if (slowdownTimer > 0) slowdownTimer--;
        if (magnetTimer > 0) magnetTimer--;
        if (shieldTimer > 0) shieldTimer--;
    }

    // 执行跳跃（包含二段跳）
    void jump() {
        if (onGround) {
            vy = JUMP_SPEED;
            onGround = false;
            jumpCount = 1;
        }
        else if (canDoubleJump && jumpCount == 1) {
            vy = DOUBLE_JUMP_SPEED;
            jumpCount = 2;
            canDoubleJump = false;
        }
    }

    // 陆地物理更新（重力 + 地面碰撞 + 边界限制）
    void updateLand() {
        vy += GRAVITY;
        y += vy;
        if (y + h >= GROUND_Y) {
            y = GROUND_Y - h;
            vy = 0;
            onGround = true;
            jumpCount = 0;
            canDoubleJump = true;
        }
        else {
            onGround = false;
        }
        // 防止跑出屏幕左右两侧
        if (x < 0) x = 0;
        if (x > WIDTH - w) x = WIDTH - w;
    }
};

// ==========================================
// 4. 游戏主逻辑类
// ==========================================
class Game {
public:
    GameState state = MENU;        // 当前游戏状态
    Player player;                 // 玩家对象
    vector<Bone> bones;            // 所有活跃的骨头
    vector<Obstacle> obstacles;    // 所有活跃的障碍物
    vector<Prop> props;            // 所有活跃的道具

    int   timeLeft = MAX_TIME;     // 剩余时间（秒）
    int   frameCount = 0;          // 总帧数计数（用于动画和计时）
    float landScrollOffset = 0;    // 陆地关卡滚动偏移量
    float waterScrollOffset = 0;   // 水上关卡滚动偏移量
    bool  levelComplete = false;   // 当前关卡是否已完成

    float finalSprintSpeed = LAND_SPEED;  // 最终冲刺阶段的速度

    int   landEndX = 18000;        // 陆地关卡终点位置
    float waterEndX = 25000;       // 水上关卡终点位置
    int   finalLandEndX = 400;     // 最终冲刺阶段小白的位置

    GameAssets assets;             // 资源管理器
    DWORD secondTimer = 0;         // 用于秒级计时的计数值

    // 场景过渡动画相关
    bool isTransitioning = false;      // 是否正在执行过渡动画
    GameState nextState = MENU;        // 过渡后的目标状态
    int transitionTimer = 0;          // 过渡动画的当前帧数
    const int transitionMax = 30;     // 过渡动画总帧数

    // ---------- BGM 切换 ----------
    void switchBGM(bool toMenu) {
        SoundManager::stopBGM("bgm");
        if (toMenu)
            SoundManager::playBGM("res/menu_bgm.mp3", "bgm");
        else
            SoundManager::playBGM("res/game_bgm.mp3", "bgm");
    }

    /**
     * 切换游戏状态
     * @param newState       目标状态
     * @param useTransition  是否启用过渡动画
     */
    void changeState(GameState newState, bool useTransition = false) {
        if (isTransitioning || state == newState) return;

        if (useTransition) {
            isTransitioning = true;
            nextState = newState;
            transitionTimer = 0;
            return;
        }

        // 立即切换
        state = newState;

        // 根据状态切换背景音乐
        if (state == MENU)
            switchBGM(true);
        else if (state == LAND_LEVEL || state == WATER_LEVEL || state == FINAL_LAND)
            switchBGM(false);

        // 初始化对应关卡
        if (state == LAND_LEVEL)      initLandLevel();
        else if (state == WATER_LEVEL) initWaterLevel();
        else if (state == FINAL_LAND)  initFinalLand();
    }

    // ---------- 构造函数 ----------
    Game() {
        srand((unsigned)time(NULL));
        assets.load();
        initLandLevel();                         // 预初始化一个关卡（首次进入菜单用）
        state = MENU;                            // 实际状态设为菜单
        SoundManager::playBGM("res/menu_bgm.mp3", "bgm");
    }

    // ---------- 析构函数 ----------
    ~Game() {
        assets.release();
        SoundManager::stopBGM("bgm");
    }

    // ---------- 关卡初始化函数 ----------
    void initLandLevel() {
        player = Player();
        // 根据加载的跑步动画帧尺寸设置玩家碰撞盒
        if (!assets.animRun.empty()) {
            player.w = assets.animRun.frameWidth;
            player.h = assets.animRun.frameHeight;
        }
        bones.clear(); obstacles.clear(); props.clear();

        timeLeft = MAX_TIME;
        secondTimer = GetTickCount();
        landScrollOffset = 0;
        levelComplete = false;

        // 获取骨头的实际尺寸
        int bw = assets.imgBone.img ? assets.imgBone.w : 24;
        int bh = assets.imgBone.img ? assets.imgBone.h : 24;

        // 生成障碍物的辅助 lambda
        auto mkOb = [&](ObstacleType t) {
            switch (t) {
            case ROCK:  return Obstacle(0, 0, ROCK, assets.imgRock.img ? assets.imgRock.w : 40, assets.imgRock.img ? assets.imgRock.h : 40);
            case PIT:   return Obstacle(0, 0, PIT, assets.imgPit.img ? assets.imgPit.w : 80, assets.imgPit.img ? assets.imgPit.h : 24);
            case STUMP: return Obstacle(0, 0, STUMP, assets.imgStump.img ? assets.imgStump.w : 30, assets.imgStump.img ? assets.imgStump.h : 50);
            default:    return Obstacle(0, 0, ROCK, 40, 40);
            }
            };

        // 沿着跑道生成障碍物（四种随机排列模式）
        for (int i = 800; i < landEndX - 800; ) {
            int pattern = rand() % 4;
            if (pattern == 0) {
                Obstacle ob = mkOb((ObstacleType)(rand() % 3));
                ob.x = (float)i;
                ob.y = (float)(GROUND_Y - ob.h);
                obstacles.push_back(ob);
                i += 300 + rand() % 150;
            }
            else if (pattern == 1) {
                Obstacle ob = mkOb((ObstacleType)(rand() % 3));
                ob.x = (float)i;
                ob.y = (float)(GROUND_Y - ob.h);
                obstacles.push_back(ob);
                i += 350 + rand() % 100;
            }
            else if (pattern == 2) {
                i += 300 + rand() % 100;   // 空跑一段距离
            }
            else if (pattern == 3) {
                Obstacle ob1 = mkOb(PIT);
                ob1.x = (float)i;
                ob1.y = (float)(GROUND_Y - ob1.h);
                obstacles.push_back(ob1);
                Obstacle ob2 = mkOb(ROCK);
                ob2.x = (float)i + ob1.w + 100;
                ob2.y = (float)(GROUND_Y - ob2.h);
                obstacles.push_back(ob2);
                i += 600 + rand() % 150;
            }
        }

        // 生成骨头（避开障碍物附近的区域）
        for (int i = 500; i < landEndX - 500; i += 120 + rand() % 80) {
            bool overlap = false;
            for (auto& ob : obstacles) {
                if (abs(i - ob.x) < 120) { overlap = true; break; }
            }
            if (overlap)
                bones.emplace_back((float)i, GROUND_Y - 240 - rand() % 40, bw, bh);
            else
                bones.emplace_back((float)i, GROUND_Y - 60 - rand() % 40, bw, bh);
        }

        // 生成道具（磁铁或护盾）
        for (int i = 1200; i < landEndX - 1000; i += 900 + rand() % 600) {
            PropType pt = (rand() % 2 == 0) ? MAGNET : SHIELD;
            props.emplace_back((float)i, GROUND_Y - 100 - rand() % 150, pt, 40, 40);
        }
    }

    void initWaterLevel() {
        player.x = 150;
        player.y = -100;            // 从屏幕上方跳入水中的初始位置
        player.vy = 15;             // 下落速度

        // 根据所选载具更新玩家尺寸
        AnimClip& clip = (player.vehicle == SURFBOARD) ? assets.animSurf : assets.animBoat;
        if (!clip.empty()) {
            player.w = clip.frameWidth;
            player.h = clip.frameHeight;
        }
        bones.clear(); obstacles.clear(); props.clear();

        timeLeft = MAX_TIME;
        secondTimer = GetTickCount();
        waterScrollOffset = 0;
        levelComplete = false;

        auto mkOb = [&](ObstacleType t) {
            switch (t) {
            case REEF:      return Obstacle(0, 0, REEF, assets.imgReef.img ? assets.imgReef.w : 50, assets.imgReef.img ? assets.imgReef.h : 40);
            case WHIRLPOOL: return Obstacle(0, 0, WHIRLPOOL, assets.imgWhirlpool.img ? assets.imgWhirlpool.w : 40, assets.imgWhirlpool.img ? assets.imgWhirlpool.h : 40);
            case SHARK:     return Obstacle(0, 0, SHARK, assets.imgShark.img ? assets.imgShark.w : 70, assets.imgShark.img ? assets.imgShark.h : 40);
            default:        return Obstacle(0, 0, REEF, 50, 40);
            }
            };

        for (int i = 400; i < waterEndX - 600; ) {
            int pattern = rand() % 3;
            if (pattern == 0) {
                ObstacleType t = (ObstacleType)(REEF + rand() % 3);
                Obstacle ob = mkOb(t);
                ob.x = (float)i;
                ob.y = 250.0f + rand() % 300;
                if (t == SHARK) ob.y = 450 + rand() % 100;
                obstacles.push_back(ob);
                i += 350 + rand() % 150;
            }
            else if (pattern == 1) {
                Obstacle ob1 = mkOb(SHARK);
                ob1.x = (float)i; ob1.y = 200 + rand() % 50;
                obstacles.push_back(ob1);
                Obstacle ob2 = mkOb(SHARK);
                ob2.x = (float)i; ob2.y = 550 + rand() % 50;
                obstacles.push_back(ob2);
                i += 500 + rand() % 150;
            }
            else {
                Obstacle ob = mkOb(WHIRLPOOL);
                ob.x = (float)i; ob.y = 300.0f + rand() % 150;
                obstacles.push_back(ob);
                i += 300 + rand() % 150;
            }
        }

        // 生成水上骨头
        int bw = assets.imgBone.img ? assets.imgBone.w : 24;
        int bh = assets.imgBone.img ? assets.imgBone.h : 24;
        for (int i = 500; i < waterEndX - 500; i += 120 + rand() % 80) {
            bones.emplace_back((float)i, 200.0f + rand() % 350, bw, bh);
        }

        // 生成水上道具
        for (int i = 1000; i < waterEndX - 1000; i += 1000 + rand() % 600) {
            PropType pt = (rand() % 2 == 0) ? MAGNET : SHIELD;
            props.emplace_back((float)i, 200.0f + rand() % 300, pt, 40, 40);
        }
    }

    void initFinalLand() {
        player.x = 50;
        player.y = GROUND_Y - player.h;
        player.vy = 0.0f;
        player.onGround = true;

        finalSprintSpeed = WALK_SPEED + 1.5f;

        if (!assets.animRun.empty()) {
            player.w = assets.animRun.frameWidth;
            player.h = assets.animRun.frameHeight;
            player.y = GROUND_Y - player.h;
        }

        bones.clear(); obstacles.clear(); props.clear();
        landScrollOffset = 0;
    }

    // ---------- 游戏主更新 ----------
    void update() {
        // 过渡动画处理
        if (isTransitioning) {
            transitionTimer++;
            if (transitionTimer == transitionMax / 2) {
                state = nextState;
                if (state == LAND_LEVEL) initLandLevel();
                else if (state == WATER_LEVEL) initWaterLevel();
                else if (state == FINAL_LAND) initFinalLand();
            }
            if (transitionTimer >= transitionMax) isTransitioning = false;
            return;
        }

        frameCount++;
        switch (state) {
        case MENU:          if (GetAsyncKeyState(VK_SPACE) & 0x8001) changeState(LAND_LEVEL, true); break;
        case LAND_LEVEL:    updateLand(); break;
        case WATER_LEVEL:   updateWater(); break;
        case FINAL_LAND:    updateFinalLand(); break;
        case VICTORY:       updateVictory(); break;
        case GAME_OVER:     updateGameOver(); break;
        }
    }

    // 共享实体更新（道具移动、磁铁吸引骨头）
    void updateSharedEntities(float currentSpeed) {
        // 道具移动与拾取检测
        for (auto& p : props) {
            p.x -= currentSpeed;
            if (p.x < -p.w) p.active = false;

            if (p.active && player.x + player.w > p.x && player.x < p.x + p.w &&
                player.y + player.h > p.y && player.y < p.y + p.h) {
                p.active = false;
                if (p.type == MAGNET) player.magnetTimer = 300;   // 磁铁持续 5 秒（300 帧）
                else if (p.type == SHIELD) player.shieldTimer = 300;
            }
        }

        // 磁铁效果：吸引附近骨头
        if (player.magnetTimer > 0) {
            float px = player.x + player.w / 2.0f;
            float py = player.y + player.h / 2.0f;
            for (auto& b : bones) {
                if (!b.active) continue;
                float bx = b.x + b.w / 2.0f;
                float by = b.y + b.h / 2.0f;
                float dist = sqrt((px - bx) * (px - bx) + (py - by) * (py - by));
                if (dist < 300.0f) {
                    float speed = 15.0f;
                    b.x += (px - bx) / dist * speed;
                    b.y += (py - by) / dist * speed;
                }
            }
        }
    }

    void updateLand() {
        if (levelComplete) return;

        // 每秒减少时间
        if (GetTickCount() - secondTimer >= 1000) {
            if (timeLeft > 0) timeLeft--;
            secondTimer += 1000;
        }
        if (timeLeft <= 0) { changeState(GAME_OVER, false); return; }

        player.updateTimers();

        // 空格跳跃（边缘检测防止连跳）
        static bool lastSpaceState = false;
        bool currentSpaceState = GetAsyncKeyState(VK_SPACE) & 0x8000;
        if (currentSpaceState && !lastSpaceState) player.jump();
        lastSpaceState = currentSpaceState;

        player.updateLand();

        // 应用减速效果
        float currentSpeed = LAND_SPEED * (player.slowdownTimer > 0 ? 0.3f : 1.0f);
        landScrollOffset += currentSpeed;

        // 靠近终点时允许切换载具（但不切换关卡）
        if (landEndX - (landScrollOffset + player.x) < 3000) {
            if (GetAsyncKeyState('1') & 0x8001) {
                player.vehicle = SURFBOARD; player.maxHp = 5; player.hp = 5;
            }
            else if ((GetAsyncKeyState('2') & 0x8001) && player.bonesCollected >= BONE_TARGET_BOAT) {
                player.vehicle = BOAT; player.maxHp = 8; player.hp = 8;
            }
        }

        // 移动所有实体
        for (auto& b : bones) { b.x -= currentSpeed; if (b.x < -b.w) b.active = false; }
        for (auto& ob : obstacles) { ob.x -= currentSpeed; if (ob.x < -ob.w) ob.active = false; }

        updateSharedEntities(currentSpeed);
        detectLandCollisions();

        // 到达陆地终点
        if (landScrollOffset + player.x >= landEndX) {
            changeState(player.bonesCollected >= BONE_TARGET ? WATER_LEVEL : GAME_OVER, true);
            return;
        }

        // 移除屏幕外实体
        auto pred = [](auto& o) { return !o.active; };
        bones.erase(std::remove_if(bones.begin(), bones.end(), pred), bones.end());
        obstacles.erase(std::remove_if(obstacles.begin(), obstacles.end(), pred), obstacles.end());
        props.erase(std::remove_if(props.begin(), props.end(), [](const Prop& p) { return !p.active; }), props.end());
    }

    void detectLandCollisions() {
        // 收集骨头
        for (auto& b : bones) {
            if (!b.active) continue;
            if (player.x + player.w > b.x - 10 && player.x < b.x + b.w + 10 &&
                player.y + player.h > b.y - 10 && player.y < b.y + b.h + 10) {
                b.active = false;
                player.bonesCollected++;
            }
        }
        // 碰撞障碍物
        for (auto& ob : obstacles) {
            if (!ob.active) continue;
            int m = 15;  // 碰撞宽容度
            if (ob.type == PIT) {
                // 坑陷阱：必须在地面上且无护盾时才触发
                if (player.shieldTimer == 0 && player.onGround &&
                    player.x + player.w > ob.x && player.x < ob.x + ob.w) {
                    changeState(GAME_OVER, false);
                    return;
                }
            }
            else {
                if (player.shieldTimer == 0 && player.invulnerableTimer == 0 &&
                    player.x + player.w - m > ob.x && player.x + m < ob.x + ob.w &&
                    player.y + player.h - m > ob.y && player.y + m < ob.y + ob.h) {
                    player.hp--;
                    player.invulnerableTimer = 60;   // 1 秒无敌
                    player.slowdownTimer = 60;       // 1 秒减速
                    if (player.hp <= 0) {
                        changeState(GAME_OVER, false);
                        return;
                    }
                }
            }
        }
    }

    void updateWater() {
        if (levelComplete) return;

        if (GetTickCount() - secondTimer >= 1000) {
            if (timeLeft > 0) timeLeft--;
            secondTimer += 1000;
        }
        if (timeLeft <= 0) { changeState(GAME_OVER, false); return; }

        player.updateTimers();

        // 玩家入水动画（前几帧自动下落到水中）
        if (player.y < 350 && waterScrollOffset < 150) {
            player.y += player.vy;
            if (player.y >= 350) { player.y = 350; player.vy = 0; }
        }
        else {
            // 正常上下移动
            if (GetAsyncKeyState(VK_UP) & 0x8000) player.y -= 7;
            if (GetAsyncKeyState(VK_DOWN) & 0x8000) player.y += 7;
            if (player.y < 50) player.y = 50;
            if (player.y + player.h > HEIGHT - 50) player.y = HEIGHT - 50 - player.h;
        }

        float baseSpeed = (player.vehicle == SURFBOARD) ? 10.0f : 15.0f;
        float currentSpeed = baseSpeed * (player.slowdownTimer > 0 ? 0.3f : 1.0f);
        waterScrollOffset += currentSpeed;

        // 移动实体（鲨鱼更快）
        for (auto& b : bones) { b.x -= currentSpeed; if (b.x < -b.w) b.active = false; }
        for (auto& ob : obstacles) {
            float obSpeed = currentSpeed;
            if (ob.type == SHARK) obSpeed += 6.0f;
            ob.x -= obSpeed;
            if (ob.x < -ob.w) ob.active = false;
        }

        updateSharedEntities(currentSpeed);
        detectWaterCollisions();

        auto pred = [](auto& o) { return !o.active; };
        bones.erase(std::remove_if(bones.begin(), bones.end(), pred), bones.end());
        obstacles.erase(std::remove_if(obstacles.begin(), obstacles.end(), pred), obstacles.end());
        props.erase(std::remove_if(props.begin(), props.end(), [](const Prop& p) { return !p.active; }), props.end());

        // 到达水上终点
        if (waterScrollOffset + player.x >= waterEndX) {
            changeState(player.bonesCollected >= BONE_TARGET_FINAL ? FINAL_LAND : GAME_OVER, true);
            return;
        }
    }

    void detectWaterCollisions() {
        // 收集骨头
        for (auto& b : bones) {
            if (!b.active) continue;
            if (player.x + player.w > b.x - 10 && player.x < b.x + b.w + 10 &&
                player.y + player.h > b.y - 10 && player.y < b.y + b.h + 10) {
                b.active = false;
                player.bonesCollected++;
            }
        }
        // 碰撞障碍物
        int m = 15;
        for (auto& ob : obstacles) {
            if (!ob.active) continue;
            if (player.shieldTimer == 0 && player.invulnerableTimer == 0 &&
                player.x + player.w - m > ob.x && player.x + m < ob.x + ob.w &&
                player.y + player.h - m > ob.y && player.y + m < ob.y + ob.h) {
                player.hp--;
                player.invulnerableTimer = 60;
                player.slowdownTimer = 60;
                if (player.hp <= 0) {
                    changeState(GAME_OVER, false);
                    return;
                }
            }
        }
    }

    void updateFinalLand() {
        // 最终冲刺阶段：不能跳跃，只能自动向前走
        player.updateLand();   // 只更新重力，不处理跳跃输入

        // 速度逐渐减慢到漫步速度
        if (finalSprintSpeed > WALK_SPEED)
            finalSprintSpeed -= 0.05f;
        else
            finalSprintSpeed = WALK_SPEED;

        landScrollOffset += finalSprintSpeed;

        float xiaobaiX = finalLandEndX - landScrollOffset;
        if (player.x + player.w >= xiaobaiX + 20) {
            changeState(VICTORY, false);
            return;
        }
    }

    void updateVictory() {
        if (GetAsyncKeyState('R') & 0x8001) changeState(LAND_LEVEL, true);
        if (GetAsyncKeyState(VK_ESCAPE) & 0x8001) changeState(MENU, false);
    }

    void updateGameOver() {
        if (GetAsyncKeyState('R') & 0x8001) changeState(LAND_LEVEL, true);
        if (GetAsyncKeyState(VK_ESCAPE) & 0x8001) changeState(MENU, false);
    }

    // ==========================================
    // 渲染辅助函数
    // ==========================================
    // 绘制带阴影的可爱文字
    void drawCuteText(int x, int y, LPCTSTR str, COLORREF mainColor = RGB(240, 248, 255)) {
        settextcolor(RGB(40, 70, 120));   // 深蓝色阴影
        outtextxy(x + 2, y + 2, str);
        settextcolor(mainColor);          // 主体颜色
        outtextxy(x, y, str);
    }

    // 绘制 UI（时间、骨头数、血量、道具状态）
    void drawUI() {
        settextstyle(28, 0, _T("幼圆"), 0, 0, 700, false, false, false);
        TCHAR buf[256];

        if (state == LAND_LEVEL) {
            swprintf_s(buf, _T("骨头: %d / %d"), player.bonesCollected, BONE_TARGET);
        }
        else if (state == WATER_LEVEL) {
            swprintf_s(buf, _T("骨头: %d / %d"), player.bonesCollected, BONE_TARGET_FINAL);
        }
        else {
            swprintf_s(buf, _T("骨头: %d"), player.bonesCollected);
        }
        drawCuteText(30, 20, buf);

        drawCuteText(30, 60, _T("血量:"));
        for (int i = 0; i < player.maxHp; i++) {
            if (i < player.hp)
                setfillcolor(RGB(255, 100, 100));   // 鲜红色
            else
                setfillcolor(0xDDDDDD);             // 灰色
            fillroundrect(140 + i * 35, 62, 165 + i * 35, 87, 15, 15);
        }

        int buffY = 105;
        if (player.magnetTimer > 0) {
            swprintf_s(buf, _T("磁力: %d"), player.magnetTimer / 60);
            drawCuteText(30, buffY, buf, RGB(255, 150, 150));
            buffY += 35;
        }
        if (player.shieldTimer > 0) {
            swprintf_s(buf, _T("护盾: %d"), player.shieldTimer / 60);
            drawCuteText(30, buffY, buf, RGB(135, 206, 250));
        }
    }

    // 绘制玩家光环（护盾/磁铁效果）
    void drawPlayerAura(int yOffset = 0) {
        int cx = (int)(player.x + player.w / 2);
        int cy = (int)(player.y + player.h / 2) + yOffset;

        if (player.shieldTimer > 0) {
            int pulse = (frameCount % 30 < 15) ? (frameCount % 15) : (15 - (frameCount % 15));
            setlinecolor(RGB(135, 206, 250));
            setlinestyle(PS_SOLID, 4);
            circle(cx, cy, player.w + pulse / 2);
            setlinestyle(PS_SOLID, 1);
        }

        if (player.magnetTimer > 0) {
            setlinecolor(RGB(255, 150, 150));
            setlinestyle(PS_SOLID, 3);
            int r1 = player.w + 30 - (frameCount * 2) % 30;
            int r2 = player.w + 30 - ((frameCount * 2) + 15) % 30;
            circle(cx, cy, r1);
            circle(cx, cy, r2);
            setlinestyle(PS_SOLID, 1);
        }
    }

    // 绘制道具
    void drawProps() {
        for (auto& p : props) {
            if (!p.active) continue;
            int dx = (int)p.x;
            IMAGE* img = (p.type == MAGNET) ? assets.imgMagnet.img : assets.imgShield.img;

            if (img) {
                putimage_alpha(dx, (int)p.y, img);
            }
            else {   // 缺失图片时绘制色块
                setfillcolor(p.type == MAGNET ? RGB(255, 150, 150) : RGB(135, 206, 250));
                fillroundrect(dx, (int)p.y, dx + p.w, (int)p.y + p.h, 20, 20);
                settextstyle(22, 0, _T("幼圆"), 0, 0, 700, false, false, false);
                drawCuteText(dx + 8, (int)p.y + 8, p.type == MAGNET ? _T("吸") : _T("盾"), RGB(255, 255, 255));
            }
        }
    }

    // 绘制场景过渡动画
    void drawTransition() {
        if (!isTransitioning) return;

        float half = transitionMax / 2.0f;
        float ratio = (transitionTimer <= half) ? (transitionTimer / half) : (1.0f - ((transitionTimer - half) / half));
        ratio = ratio * ratio * (3 - 2 * ratio);   // 缓动函数

        if (nextState == WATER_LEVEL) {
            // 波浪上升动画
            int baseHeight = (int)(HEIGHT * ratio);
            int baseY = HEIGHT - baseHeight;
            setfillcolor(RGB(65, 105, 225));
            POINT pts[65];
            int ptCount = 0;
            pts[ptCount++] = { 0, HEIGHT };
            float phase = frameCount * 0.3f;
            float amplitude = min(25.0f, (float)baseHeight);
            for (int x = 0; x <= WIDTH; x += WIDTH / 60) {
                int y = baseY + (int)(amplitude * sin(x * 0.02f + phase));
                pts[ptCount++] = { x, y };
            }
            pts[ptCount++] = { WIDTH, HEIGHT };
            solidpolygon(pts, ptCount);
        }
        else if (nextState == FINAL_LAND) {
            int w = (int)(WIDTH * ratio);
            setfillcolor(RGB(139, 69, 19));
            solidrectangle(WIDTH - w, 0, WIDTH, HEIGHT);
        }
        else {
            int h = (int)((HEIGHT / 2) * ratio) + 2;
            setfillcolor(RGB(30, 30, 50));
            solidrectangle(0, 0, WIDTH, h);
            solidrectangle(0, HEIGHT - h, WIDTH, HEIGHT);
        }
    }

    // 主绘制函数
    void draw() {
        cleardevice();
        switch (state) {
        case MENU:          drawMenu(); break;
        case LAND_LEVEL:    drawLand(); break;
        case WATER_LEVEL:   drawWater(); break;
        case FINAL_LAND:    drawFinalLand(); break;
        case VICTORY:       drawVictory(); break;
        case GAME_OVER:     drawGameOver(); break;
        }
        drawTransition();
    }

    void drawMenu() {
        if (assets.imgMenuBg.img)
            putimage(0, 0, assets.imgMenuBg.img);
        else {
            setfillcolor(0x87CEEB);
            solidrectangle(0, 0, WIDTH, HEIGHT);
            settextstyle(48, 0, _T("幼圆"), 0, 0, 700, false, false, false);
            drawCuteText(400, 300, _T("封面缺失"));
        }
    }

    void drawLand() {
        // 绘制循环背景（裁掉边缘脏像素）
        if (assets.imgLoopingBg.img) {
            int bgW = assets.imgLoopingBg.w;
            int bgH = assets.imgLoopingBg.h;
            int trim = 2;
            int validW = bgW - trim * 2;
            if (validW > 0) {
                int dx = -((int)landScrollOffset % validW);
                putimage(dx, 0, validW, bgH, assets.imgLoopingBg.img, trim, 0);
                if (dx + validW < WIDTH)
                    putimage(dx + validW, 0, validW, bgH, assets.imgLoopingBg.img, trim, 0);
                if (dx + validW * 2 < WIDTH)
                    putimage(dx + validW * 2, 0, validW, bgH, assets.imgLoopingBg.img, trim, 0);
            }
        }
        else {
            setfillcolor(0x87CEEB); solidrectangle(0, 0, WIDTH, GROUND_Y);
            setfillcolor(0x8B4513); solidrectangle(0, GROUND_Y, WIDTH, HEIGHT);
        }

        // 骨头
        for (auto& b : bones) {
            int dx = (int)b.x;
            if (assets.imgBone.img)
                putimage_alpha(dx, (int)b.y, assets.imgBone.img);
            else {
                setfillcolor(0xFFFFE0);
                solidellipse(dx, (int)b.y, dx + b.w, (int)b.y + b.h);
            }
        }

        drawProps();

        // 障碍物
        for (auto& ob : obstacles) {
            int dx = (int)ob.x;
            int dy = (int)ob.y + OBSTACLE_VISUAL_OFFSET;
            IMAGE* img = nullptr;
            switch (ob.type) {
            case ROCK:  img = assets.imgRock.img; break;
            case PIT:   img = assets.imgPit.img; break;
            case STUMP: img = assets.imgStump.img; break;
            }
            if (img) putimage_alpha(dx, dy, img);
            else { setfillcolor(0x808080); solidrectangle(dx, dy, dx + ob.w, dy + ob.h); }
        }

        // 玩家动画
        AnimClip* clip = player.onGround ? &assets.animRun : &assets.animJump;
        IMAGE* frame = clip->update();
        if (player.invulnerableTimer == 0 || (player.invulnerableTimer / 5) % 2 == 0) {
            drawPlayerAura(VISUAL_Y_OFFSET);
            if (frame)
                putimage_alpha((int)player.x, (int)player.y + VISUAL_Y_OFFSET, frame);
            else {
                setfillcolor(0xFFD700);
                solidellipse((int)player.x, (int)player.y + VISUAL_Y_OFFSET,
                    (int)player.x + player.w, (int)player.y + player.h + VISUAL_Y_OFFSET);
            }
        }

        // 靠近终点时提示切换载具
        if (landEndX - (landScrollOffset + player.x) < 3000) {
            settextstyle(32, 0, _T("幼圆"), 0, 0, 700, false, false, false);
            drawCuteText(WIDTH / 2 - 280, 150, _T("即将跃入水中！请按 1或2 提前准备好载具"));
            COLORREF c1 = (player.vehicle == SURFBOARD) ? RGB(100, 200, 255) : RGB(240, 248, 255);
            drawCuteText(WIDTH / 2 - 150, 210, _T("1. 冲浪板 (轻盈灵敏)"), c1);
            if (player.bonesCollected >= BONE_TARGET_BOAT) {
                COLORREF c2 = (player.vehicle == BOAT) ? RGB(100, 200, 255) : RGB(240, 248, 255);
                drawCuteText(WIDTH / 2 - 150, 260, _T("2. 小船 (极速装甲)"), c2);
            }
            else {
                drawCuteText(WIDTH / 2 - 150, 260, _T("2. 小船 (缺骨头未解锁)"), RGB(180, 180, 180));
            }
        }
        drawUI();
    }

    void drawWater() {
        if (assets.imgWater.img)
            putimage(0, 0, assets.imgWater.img);
        else
            setfillcolor(0x4682B4), solidrectangle(0, 0, WIDTH, HEIGHT);

        for (auto& b : bones) {
            int dx = (int)b.x;
            if (assets.imgBone.img)
                putimage_alpha(dx, (int)b.y, assets.imgBone.img);
            else {
                setfillcolor(0xFFFFE0);
                solidellipse(dx, (int)b.y, dx + b.w, (int)b.y + b.h);
            }
        }

        drawProps();

        for (auto& ob : obstacles) {
            int dx = (int)ob.x;
            IMAGE* img = nullptr;
            switch (ob.type) {
            case REEF:      img = assets.imgReef.img; break;
            case WHIRLPOOL: img = assets.imgWhirlpool.img; break;
            case SHARK:     img = assets.imgShark.img; break;
            }
            if (img) putimage_alpha(dx, (int)ob.y, img);
            else { setfillcolor(0x808080); solidrectangle(dx, (int)ob.y, dx + ob.w, (int)ob.y + ob.h); }
        }

        AnimClip* clip = (player.vehicle == SURFBOARD) ? &assets.animSurf : &assets.animBoat;
        IMAGE* frame = clip->update();
        if (player.invulnerableTimer == 0 || (player.invulnerableTimer / 5) % 2 == 0) {
            drawPlayerAura(0);
            if (frame)
                putimage_alpha((int)player.x, (int)player.y, frame);
            else {
                setfillcolor(0xFFD700);
                solidellipse((int)player.x, (int)player.y, (int)player.x + player.w, (int)player.y + player.h);
            }
        }
        drawUI();
    }

    void drawFinalLand() {
        if (assets.imgLoopingBg.img) {
            int bgW = assets.imgLoopingBg.w;
            int bgH = assets.imgLoopingBg.h;
            int trim = 2;
            int validW = bgW - trim * 2;
            if (validW > 0) {
                int dx = -((int)landScrollOffset % validW);
                putimage(dx, 0, validW, bgH, assets.imgLoopingBg.img, trim, 0);
                if (dx + validW < WIDTH)
                    putimage(dx + validW, 0, validW, bgH, assets.imgLoopingBg.img, trim, 0);
                if (dx + validW * 2 < WIDTH)
                    putimage(dx + validW * 2, 0, validW, bgH, assets.imgLoopingBg.img, trim, 0);
            }
        }
        else {
            setfillcolor(0x87CEEB); solidrectangle(0, 0, WIDTH, GROUND_Y);
            setfillcolor(0x8B4513); solidrectangle(0, GROUND_Y, WIDTH, HEIGHT);
        }

        int xiaobaiX = (int)(finalLandEndX - landScrollOffset);
        if (assets.imgXiaobai.img)
            putimage_alpha(xiaobaiX, GROUND_Y - assets.imgXiaobai.h, assets.imgXiaobai.img);
        else {
            setfillcolor(0xFF00FF);
            solidrectangle(xiaobaiX, GROUND_Y - 80, xiaobaiX + 60, GROUND_Y);
            settextstyle(20, 0, _T("幼圆"), 0, 0, 700, false, false, false);
            drawCuteText(xiaobaiX + 5, GROUND_Y - 50, _T("小白"));
        }

        AnimClip* clip = player.onGround ? &assets.animRun : &assets.animJump;
        IMAGE* frame = clip->update();
        if (frame)
            putimage_alpha((int)player.x, (int)player.y + VISUAL_Y_OFFSET, frame);
        else {
            setfillcolor(0xFFD700);
            solidellipse((int)player.x, (int)player.y + VISUAL_Y_OFFSET,
                (int)player.x + player.w, (int)player.y + player.h + VISUAL_Y_OFFSET);
        }
    }

    void drawVictory() {
        if (assets.imgEndBg.img)
            putimage(0, 0, assets.imgEndBg.img);
        else {
            setfillcolor(0x228B22); solidrectangle(0, 0, WIDTH, HEIGHT);
            settextstyle(48, 0, _T("幼圆"), 0, 0, 700, false, false, false);
            drawCuteText(WIDTH / 2 - 140, HEIGHT / 2 - 60, _T("胜利！通关！"));
            settextstyle(24, 0, _T("幼圆"), 0, 0, 700, false, false, false);
            drawCuteText(WIDTH / 2 - 160, HEIGHT / 2 + 20, _T("按R重新挑战  ESC返回菜单"));
        }
    }

    void drawGameOver() {
        if (assets.imgGameOver.img)
            putimage(0, 0, assets.imgGameOver.img);
        else {
            setfillcolor(0x333333); solidrectangle(0, 0, WIDTH, HEIGHT);
            settextstyle(48, 0, _T("幼圆"), 0, 0, 700, false, false, false);
            drawCuteText(WIDTH / 2 - 100, HEIGHT / 2 - 60, _T("挑战失败"), RGB(255, 100, 100));
            settextstyle(24, 0, _T("幼圆"), 0, 0, 700, false, false, false);
            drawCuteText(WIDTH / 2 - 180, HEIGHT / 2 + 20, _T("按R重新挑战  ESC返回菜单"));
        }
    }
};

// ==========================================
// 5. 引擎入口点
// ==========================================
int main() {
    initgraph(WIDTH, HEIGHT);
    setbkcolor(0xFFFFFF);
    setbkmode(TRANSPARENT);

    BeginBatchDraw();          // 开启双缓冲，避免闪烁
    Game game;

    while (true) {
        if (_kbhit() && _getch() == 27) break;   // ESC 键退出
        game.update();
        game.draw();
        FlushBatchDraw();      // 刷新画面
        Sleep(16);            // 控制帧率约 60 FPS
    }

    EndBatchDraw();
    closegraph();
    return 0;
}
