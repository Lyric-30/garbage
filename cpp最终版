// 帧动画剪辑（多张图片循环播放）
struct AnimClip {
    vector<IMAGE*> frames;          // 帧图像列表
    int frameDelay;                 // 每帧停留的帧数（控制播放速度）
    int currentFrame;               // 当前帧索引
    int timer;                      // 内部计时器
    int frameWidth = 0, frameHeight = 0;  // 帧的宽高（假设所有帧尺寸相同）

    AnimClip() : frameDelay(5), currentFrame(0), timer(0) {}

    /**
     * 添加一帧图片到动画中
     * @param path 图片路径
     */
    void addFrame(LPCTSTR path) {
        IMAGE* img = new IMAGE();
        loadimage(img, path);
        if (img->getwidth() == 0) { delete img; return; }  // 加载失败则跳过
        frames.push_back(img);
        if (frameWidth == 0) {
            frameWidth = img->getwidth();
            frameHeight = img->getheight();
        }
    }

    /**
     * 更新动画并返回当前帧的 IMAGE 指针
     * @return 当前帧图像，若没有帧则返回 nullptr
     */
    IMAGE* update() {
        if (frames.empty()) return nullptr;
        timer++;
        if (timer >= frameDelay) {
            timer = 0;
            currentFrame = (currentFrame + 1) % frames.size();
        }
        return frames[currentFrame];
    }

    // 重置到第一帧
    void reset() { currentFrame = 0; timer = 0; }

    // 释放所有帧占用的内存
    void release() {
        for (auto& p : frames) delete p;
        frames.clear();
    }

    bool empty() const { return frames.empty(); }
};

/**
 * 游戏资源总管理类
 * 负责所有图片和动画的加载、存储与释放
 */
struct GameAssets {
    // 动画对象
    AnimClip animRun, animJump, animSurf, animBoat;

    // 单张图片信息（图片指针 + 实际宽高）
    struct ImageInfo {
        IMAGE* img = nullptr;
        int w = 0, h = 0;
    };

    // 道具与障碍物
    ImageInfo imgBone, imgRock, imgPit, imgStump;
    ImageInfo imgReef, imgWhirlpool, imgShark;
    // 背景图
    ImageInfo imgLoopingBg;        // 长背景（循环滚动）
    ImageInfo imgWater;            // 水面背景
    ImageInfo imgMenuBg;           // 菜单界面图
    ImageInfo imgEndBg;            // 胜利界面图
    ImageInfo imgXiaobai;          // 小白角色图
    // 道具图标
    ImageInfo imgMagnet, imgShield;
    // 失败界面图（可选）
    ImageInfo imgGameOver;

    /**
     * 加载一组动画帧
     * @param clip       动画剪辑对象
     * @param baseName   基础文件名（如 "run"，实际加载 run_1.png 等）
     * @param frameCount 帧数
     */
    void loadAnimClip(AnimClip& clip, const TCHAR* baseName, int frameCount) {
        for (int i = 1; i <= frameCount; ++i) {
            TCHAR path[256];
            _stprintf_s(path, _T("res/%s_%d.png"), baseName, i);
            clip.addFrame(path);
        }
    }

    /**
     * 加载单张图片（支持可选缩放）
     * @param info      存储图片的信息结构
     * @param path      图片路径
     * @param resizeW   若 >0 则缩放至指定宽度
     * @param resizeH   若 >0 则缩放至指定高度
     */
    void loadImage(ImageInfo& info, LPCTSTR path, int resizeW = 0, int resizeH = 0) {
        IMAGE* temp = new IMAGE();
        if (resizeW > 0 && resizeH > 0)
            loadimage(temp, path, resizeW, resizeH, true);  // 带缩放加载
        else
            loadimage(temp, path);                           // 原尺寸加载

        if (temp->getwidth() == 0) {
            delete temp;
            info.img = nullptr;   // 加载失败则置空，后续用色块替代
        }
        else {
            info.img = temp;
            info.w = temp->getwidth();
            info.h = temp->getheight();
        }
    }

    // 加载所有游戏资源
    void load() {
        // 角色动画帧
        loadAnimClip(animRun, _T("run"), 4);
        loadAnimClip(animJump, _T("jump"), 2);
        loadAnimClip(animSurf, _T("surf"), 3);
        loadAnimClip(animBoat, _T("boat"), 3);

        // 障碍物与收集物
        loadImage(imgBone, _T("res/bone.png"));
        loadImage(imgRock, _T("res/rock.png"));
        loadImage(imgPit, _T("res/pit.png"));
        loadImage(imgStump, _T("res/stump.png"));
        loadImage(imgReef, _T("res/reef.png"));
        loadImage(imgWhirlpool, _T("res/whirlpool.png"));
        loadImage(imgShark, _T("res/shark.png"));

        // 背景
        loadImage(imgLoopingBg, _T("res/long_bg.png"));
        loadImage(imgWater, _T("res/water.png"), WIDTH, HEIGHT);    // 拉伸至窗口尺寸
        loadImage(imgMenuBg, _T("res/menu_bg.png"), WIDTH, HEIGHT);
        loadImage(imgEndBg, _T("res/end_bg.png"), WIDTH, HEIGHT);
        loadImage(imgXiaobai, _T("res/xiaobai.png"));

        // 道具图标
        loadImage(imgMagnet, _T("res/magnet.png"), 40, 40);
        loadImage(imgShield, _T("res/shield.png"), 40, 40);
        loadImage(imgGameOver, _T("res/game_over.png"), WIDTH, HEIGHT);
    }

    // 释放所有资源
    void release() {
        animRun.release(); animJump.release(); animSurf.release(); animBoat.release();
        auto del = [](ImageInfo& info) { if (info.img) delete info.img; };
        del(imgBone); del(imgRock); del(imgPit); del(imgStump);
        del(imgReef); del(imgWhirlpool); del(imgShark);
        del(imgLoopingBg); del(imgWater);
        del(imgMenuBg); del(imgEndBg); del(imgXiaobai);
        del(imgMagnet); del(imgShield);
        del(imgGameOver);
    }
};

