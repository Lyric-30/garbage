// ==========================================
// Alpha 透明混合贴图函数
// 作用：将带透明通道的 PNG 图片正确绘制到窗口缓冲上
// ==========================================
void putimage_alpha(int x, int y, IMAGE* img) {
    int w = img->getwidth();
    int h = img->getheight();
    DWORD* dst = GetImageBuffer();        // 窗口绘图缓冲区
    DWORD* src = GetImageBuffer(img);     // 图片像素缓冲区
    int dst_w = getwidth();
    int dst_h = getheight();

    for (int iy = 0; iy < h; iy++) {
        for (int ix = 0; ix < w; ix++) {
            int px = x + ix, py = y + iy;
            if (px < 0 || px >= dst_w || py < 0 || py >= dst_h) continue;

            DWORD s = src[iy * w + ix];
            byte a = (byte)(s >> 24);      // Alpha 值
            if (a == 0) continue;          // 完全透明跳过

            DWORD d = dst[py * dst_w + px];
            byte d_r = (byte)d, d_g = (byte)(d >> 8), d_b = (byte)(d >> 16);
            byte s_r = (byte)s, s_g = (byte)(s >> 8), s_b = (byte)(s >> 16);

            // 按照 Alpha 混合公式计算新颜色
            dst[py * dst_w + px] = RGB(
                (d_r * (255 - a) + s_r * a) >> 8,
                (d_g * (255 - a) + s_g * a) >> 8,
                (d_b * (255 - a) + s_b * a) >> 8
            );
        }
    }
}

