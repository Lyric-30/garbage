// ==========================================
// 音效管理器 —— 仅保留背景音乐功能
// ==========================================
class SoundManager {
public:
    /**
     * 播放背景音乐（循环播放）
     * @param path  音乐文件路径（支持 mp3、wav 等）
     * @param alias 给当前音乐分配的别名，用于后续停止和切换
     */
    static void playBGM(const char* path, const char* alias) {
        char cmd[256];
        // 先停止并关闭之前同别名的音乐
        sprintf_s(cmd, "stop %s", alias);   mciSendStringA(cmd, NULL, 0, NULL);
        sprintf_s(cmd, "close %s", alias);  mciSendStringA(cmd, NULL, 0, NULL);
        // 打开并循环播放新音乐
        sprintf_s(cmd, "open %s alias %s", path, alias); mciSendStringA(cmd, NULL, 0, NULL);
        sprintf_s(cmd, "play %s repeat", alias);         mciSendStringA(cmd, NULL, 0, NULL);
    }

    /**
     * 停止背景音乐并释放资源
     * @param alias 音乐别名
     */
    static void stopBGM(const char* alias) {
        char cmd[256];
        sprintf_s(cmd, "stop %s", alias);  mciSendStringA(cmd, NULL, 0, NULL);
        sprintf_s(cmd, "close %s", alias); mciSendStringA(cmd, NULL, 0, NULL);
    }
};

